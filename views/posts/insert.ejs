<div class="my-5">
    <h1 class="text-center mb-5">글쓰기</h1>
    <div class="row justify-content-center">
        <div class="col-10 col-md-8 col-lg-6">
            <form name="frm">
                <div class="input-group mb-3">
                    <span class="input-group-text">학번</span>
                    <!-- 로그인한 사람의 학번이 자동으로 들어가도록 id 부여, 임의 수정 방지(readonly) -->
                    <input class="form-control" name="scode" id="login_scode" readonly>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text">글 내용</span>
                    <textarea class="form-control" name="content" rows="6" placeholder="자유롭게 글을 남겨주세요." required></textarea>
                </div>
                <div class="text-center mt-3">
                    <button class="btn btn-primary px-5" type="submit">등록</button>
                    <button class="btn btn-secondary px-5" type="button" onclick="location.href='/posts'">취소</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // 로그인 상태 확인 및 학번 자동 입력
    if (sessionStorage.getItem("scode")) {
        $("#login_scode").val(sessionStorage.getItem("scode"));
    } else {
        alert("로그인이 필요한 서비스입니다.");
        location.href = "/users/login";
    }

    $(frm).on("submit", function(e) {
        e.preventDefault();
        if (confirm("게시글을 등록하시겠습니까?")) {
            $.ajax({
                type: "post",
                url: "/posts/insert",
                data: $(frm).serialize(),
                success: function() {
                    alert("게시글 등록 완료!");
                    location.href = "/posts"; // 목록으로 돌아가기
                },
                error: function() {
                    alert("게시글 등록에 실패했습니다.");
                }
            });
        }
    });
</script>